{
    "name": "wanted/whatsapp-stream-crypto",
    "description": "PSR-7 stream decorators for WhatsApp media encryption and decryption",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.1|^2.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Wanted\\WhatsAppStreamCrypto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wanted\\WhatsAppStreamCrypto\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
